MATCH (item: LINEITEM)-[:COMPOSED_BY]->(part: PART)
WHERE item.L_SHIPDATE >= date("1997-05-01") AND item.L_SHIPDATE < date("1997-06-01")
RETURN 100 * SUM(CASE WHEN part.P_TYPE STARTS WITH "PROMO" THEN item.L_EXTENDEDPRICE*(1 - item.L_DISCOUNT) ELSE 0 END) / SUM(item.L_EXTENDEDPRICE * (1 - item.L_DISCOUNT)) AS PROMO_REVENUE;