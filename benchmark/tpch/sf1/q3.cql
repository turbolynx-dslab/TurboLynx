MATCH (lineitem:LINEITEM)-[:IS_PART_OF]->(ord:ORDERS)-[:MADE_BY]->(customer:CUSTOMER)
WHERE customer.C_MKTSEGMENT = "FURNITURE" AND date(ord.O_ORDERDATE) < date("1995-03-07") AND date(lineitem.L_SHIPDATE) > date("1995-03-07")
RETURN ord.O_ORDERKEY, sum(lineitem.L_EXTENDEDPRICE*(1-lineitem.L_DISCOUNT)) AS REVENUE, ord.O_ORDERDATE, ord.O_SHIPPRIORITY
ORDER BY REVENUE DESC, ord.O_ORDERDATE
LIMIT 10;