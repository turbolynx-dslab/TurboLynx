MATCH (li:LINEITEM)-[:IS_PART_OF]->(o:ORDERS)-[:MADE_BY]->(c:CUSTOMER)-[:CUST_BELONG_TO]->(n:NATION)
WHERE date(o.O_ORDERDATE) >= date("1993-07-01")
and date(o.O_ORDERDATE) < date("1993-10-01")
and li.L_RETURNFLAG = "R"
RETURN c.C_CUSTKEY,c.C_NAME, sum(li.L_EXTENDEDPRICE * (1-li.L_DISCOUNT)) as revenue, c.C_ACCTBAL, n.N_NAME, c.C_ADDRESS, c.C_PHONE, c.C_COMMENT
ORDER BY revenue desc
LIMIT 20;