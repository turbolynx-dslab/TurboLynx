FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Core build tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gcc-11 g++-11 \
    cmake \
    ninja-build \
    git \
    autoconf automake libtool \
    pkg-config \
    ca-certificates \
    # Runtime/system libs still needed by the project
    libtbb-dev \
    libssl-dev \
    libaio-dev \
    libnuma-dev \
    libhwloc-dev \
    libboost-all-dev \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

RUN update-alternatives \
    --install /usr/bin/gcc gcc /usr/bin/gcc-11 60 \
    --slave   /usr/bin/g++ g++ /usr/bin/g++-11

WORKDIR /turbograph-v3
