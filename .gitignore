# Refer to https://github.com/github/gitignore for useful templates

# General build files
build*/
build/
tmp/
site/

# Logs and temporary files
*.log
logs/*
*.html
!docs/overrides/*.html
*.csv
*.csv.backward

# C/C++
*.o
*.ko
*.obj
*.elf
*.slo
*.lo
*.so
*.a
*.bin
*.exe
*.d
*.dSYM/
*.out
*.h.gch

# Python
__pycache__/
*.py[cod]
*.pyo

# Java
*.class
*.jar
*.war
*.ear

# OS-specific
.DS_Store
._*
Thumbs.db
*.ini

# Editor-specific
*.swp
.idea/
*.code-workspace 
.vscode/

# Miscellaneous
r*hs

.cache

# pnpm
.pnpm-store/

# Claude Code local workspace (settings, worktrees, agent state — machine-specific)
.claude/

# Local working notes (not for public repo)
CLAUDE.md
PLAN.md
*.report

# Next.js build output
demo/.next/

# Local-only convenience symlink so `mkdocs serve` can pick up the
# agentic demo's Next.js static export. Recreate locally with:
#   ln -sfn ../demo/agentic-demo/app/out docs/demo-agentic
docs/demo-agentic

# ANTLR generated files
third_party/antlr4_cypher/antlr4/generated/

# Test result artifacts
*.result.json

# Applications (real-world app harnesses under applications/)
applications/**/data/raw/
applications/**/data/csv/
applications/**/workspace*/
applications/**/*.egg-info/
applications/**/app/dist/
applications/**/app/.eggs/
.pytest_cache/

# Allow committed fixture CSVs and .csv.backward files despite the
# global *.csv / *.csv.backward ignores above
!applications/oss-supply-chain/tests/fixtures/*.csv
!applications/oss-supply-chain/tests/fixtures/*.csv.backward
!applications/cloud-attack-graph/tests/fixtures/*.csv
!applications/cloud-attack-graph/tests/fixtures/*.csv.backward

# Allow per-application planning docs despite the repo-wide PLAN.md ignore
# (macOS APFS is case-insensitive, so plan.md matches the PLAN.md rule)
!applications/**/tasks/plan.md
